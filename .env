# OpenWebUI backend configuration
OPENWEBUI_BASE_URL=http://localhost:8080

# SSL verification (set to false for self-signed certificates)
OPENWEBUI_VERIFY_SSL=true

# Flask configuration
FLASK_DEBUG=false
FLASK_HOST=0.0.0.0
FLASK_PORT=5001

# Logging configuration
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Request timeout configuration (in seconds)
REQUEST_TIMEOUT=30
CHAT_COMPLETION_TIMEOUT=120
READINESS_TIMEOUT=5

# Rate limiting
# Format: "N per second/minute/hour/day" (e.g. "100 per minute")
RATE_LIMIT_GLOBAL=100 per minute
RATE_LIMIT_MODELS=30 per minute
RATE_LIMIT_CHAT=30 per minute

# CORS configuration
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=*
CORS_ALLOW_METHODS=GET, POST, PUT, DELETE, OPTIONS
CORS_ALLOW_HEADERS=Content-Type, Authorization
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

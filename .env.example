# OpenWebUI backend configuration
OPENWEBUI_BASE_URL=http://localhost:3000

# SSL verification (set to false for self-signed certificates)
OPENWEBUI_VERIFY_SSL=true

# Flask configuration
FLASK_DEBUG=false
FLASK_HOST=0.0.0.0
FLASK_PORT=5001

# Logging configuration
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Request timeout configuration (in seconds)
REQUEST_TIMEOUT=30
CHAT_COMPLETION_TIMEOUT=120
READINESS_TIMEOUT=5

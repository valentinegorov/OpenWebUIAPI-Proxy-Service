# OpenWebUI Proxy Server Environment Configuration
# Copy this file to .env and fill in your values

# Required: OpenWebUI backend URL (e.g., http://localhost:3000 or https://openwebui.example.com)
OPENWEBUI_BASE_URL=http://localhost:3000

# Optional: Enable debug mode for development (true/false, default: false)
# WARNING: Do not enable in production!
FLASK_DEBUG=false

# Optional: Flask environment (development/production, default: production)
FLASK_ENV=production
